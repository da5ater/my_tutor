<footer class="bg-white border-top mt-auto" style="border-top-color: #ebebeb !important;">
  <!-- Footer Links Section -->
  <div class="container py-5" style="padding-top: 48px !important; padding-bottom: 48px !important;">
    <div class="row g-4">
      <!-- Column 1: Support -->
      <div class="col-12 col-md-4">
        <h6 class="text-dark fw-bold mb-3 font-heading" style="font-size: 0.9rem; letter-spacing: 0.2px;">Support</h6>
        <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
          <li><%= link_to "Help Center", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "Safety Information", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "Cancellation Options", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "Student Support", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "Tutor Support", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
        </ul>
      </div>

      <!-- Column 2: Teaching -->
      <div class="col-12 col-md-4">
        <h6 class="text-dark fw-bold mb-3 font-heading" style="font-size: 0.9rem; letter-spacing: 0.2px;">Teaching</h6>
        <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
          <li><%= link_to "Teach on My Tutor", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "Tutor Resources", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "Community Forum", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "Tutoring Responsibly", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "Tutor Guarantee", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
        </ul>
      </div>

      <!-- Column 3: My Tutor -->
      <div class="col-12 col-md-4">
        <h6 class="text-dark fw-bold mb-3 font-heading" style="font-size: 0.9rem; letter-spacing: 0.2px;">My Tutor</h6>
        <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
          <li><%= link_to "About Us", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "Careers", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "Newsroom", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "New Features", "#", class: "text-secondary text-decoration-none small hover-underline" %></li>
          <li><%= link_to "Privacy Policy", privacy_policy_path, class: "text-secondary text-decoration-none small hover-underline" %></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Legal Band -->
  <div class="border-top py-4 bg-light" style="border-top-color: #ebebeb !important;">
    <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
      <div class="d-flex flex-wrap align-items-center gap-2 text-muted small">
        <span>© <%= Time.current.year %> My Tutor, Inc.</span>
        <span class="d-none d-md-inline">•</span>
        <%= link_to "Privacy", privacy_policy_path, class: "text-muted text-decoration-none hover-underline" %>
        <span>•</span>
        <%= link_to "Terms", "#", class: "text-muted text-decoration-none hover-underline" %>
        <span>•</span>
        <%= link_to "Sitemap", "#", class: "text-muted text-decoration-none hover-underline" %>
      </div>

      <div class="d-flex align-items-center gap-4">
        <!-- Language / Currency Pickers -->
        <div class="d-flex align-items-center gap-3 small">
          <a href="#" class="text-dark fw-bold text-decoration-none d-flex align-items-center gap-1 hover-underline">
            <i class="fa-solid fa-globe text-secondary"></i> English (US)
          </a>
          <a href="#" class="text-dark fw-bold text-decoration-none hover-underline">
            $ USD
          </a>
        </div>

        <!-- Social Icons -->
        <div class="d-flex align-items-center gap-3">
          <a href="#" class="text-dark hover-opacity" aria-label="Facebook"><i class="fa-brands fa-facebook-f text-secondary"></i></a>
          <a href="#" class="text-dark hover-opacity" aria-label="Twitter"><i class="fa-brands fa-x-twitter text-secondary"></i></a>
          <a href="#" class="text-dark hover-opacity" aria-label="Instagram"><i class="fa-brands fa-instagram text-secondary"></i></a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .hover-underline:hover {
    text-decoration: underline !important;
  }
  .hover-opacity:hover {
    opacity: 0.7;
  }
</style>
