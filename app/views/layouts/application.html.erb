<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "My Tutor - Find Expert Private Tutors Online" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="My Tutor">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Modern Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Bootstrap 5.3.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <!-- Local Application Stylesheet (overrides) -->
    <%= stylesheet_link_tag "trix", "actiontext", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom py-3 sticky-top">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2 fw-bold text-dark font-heading fs-4" do %>
          <i class="fa-solid fa-graduation-cap fs-3" style="color: #ff385c !important;"></i>
          <span>My<span style="color: #ff385c;">Tutor</span></span>
        <% end %>
        
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
          <% if user_signed_in? %>
            <%= search_form_for @ransack_courses, as: :courses_search, url: courses_path, method: :get, html: { class: "d-none d-md-flex align-items-center gap-2 bg-light p-1 rounded-pill border me-auto mb-0", role: "search" } do |f| %>
              <%= f.search_field :title_or_short_description_cont, placeholder: "Search courses...", aria: { label: "Search courses" }, class: "form-control border-0 bg-transparent py-1 px-3 small", style: "box-shadow: none; font-size: 0.85rem; color: #222; min-width: 0;" %>
              <%= f.button type: :submit, class: "btn btn-primary rounded-circle p-1 d-flex align-items-center justify-content-center flex-shrink-0", style: "width: 28px; height: 28px;", title: "Search courses", aria: { label: "Search courses" } do %>
                <i class="fa-solid fa-magnifying-glass" style="font-size: 0.75rem;"></i>
              <% end %>
            <% end %>
          <% end %>

          <ul class="navbar-nav align-items-center ms-auto gap-1">
            <li class="nav-item">
              <%= link_to "Courses", courses_path, class: "nav-link fw-bold px-3 text-secondary" %>
            </li>
            
            <% if current_user %>
              <!-- Learn Dropdown (Student) -->
              <% if current_user.has_role?(:student) %>
                <li class="nav-item dropdown" id="learnDropdown">
                  <a class="nav-link dropdown-toggle fw-bold px-3 text-secondary d-flex align-items-center gap-1" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fa-solid fa-graduation-cap"></i> Learn
                  </a>
                  <ul class="dropdown-menu dropdown-menu-end shadow border border-light-subtle rounded-3 mt-2" style="min-width: 200px;">
                    <li>
                      <%= link_to purchased_courses_path, class: "dropdown-item py-2 small fw-semibold d-flex align-items-center justify-content-between" do %>
                        <span><i class="fa-solid fa-book-open me-2 text-secondary"></i> My Courses</span>
                        <span class="badge bg-secondary text-white rounded-pill px-2 py-0.5" style="font-size: 0.7rem;"><%= current_user.respond_to?(:enrollments_count) ? current_user.enrollments_count : current_user.enrollments.count %></span>
                      <% end %>
                    </li>
                    <li>
                      <%= link_to pending_review_courses_path, class: "dropdown-item py-2 small fw-semibold d-flex align-items-center justify-content-between" do %>
                        <span><i class="fa-regular fa-star me-2 text-secondary"></i> Pending Reviews</span>
                        <span class="badge bg-secondary text-white rounded-pill px-2 py-0.5" style="font-size: 0.7rem;"><%= current_user.enrollments.pending_review.count %></span>
                      <% end %>
                    </li>
                  </ul>
                </li>
              <% end %>

              <!-- Teach Dropdown (Teacher) -->
              <% if current_user.has_role?(:teacher) %>
                <li class="nav-item dropdown" id="teachDropdown">
                  <a class="nav-link dropdown-toggle fw-bold px-3 text-secondary d-flex align-items-center gap-1" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fa-solid fa-chalkboard-user"></i> Teach
                  </a>
                  <ul class="dropdown-menu dropdown-menu-end shadow border border-light-subtle rounded-3 mt-2" style="min-width: 220px;">
                    <li>
                      <%= link_to new_course_path, class: "dropdown-item py-2 small fw-semibold" do %>
                        <i class="fa-solid fa-plus me-1 text-secondary"></i><i class="fa-solid fa-graduation-cap me-2 text-secondary"></i> New Course
                      <% end %>
                    </li>
                    <li>
                      <%= link_to created_courses_path, class: "dropdown-item py-2 small fw-semibold d-flex align-items-center justify-content-between" do %>
                        <span><i class="fa-solid fa-book me-2 text-secondary"></i> My Created Courses</span>
                        <span class="badge bg-secondary text-white rounded-pill px-2 py-0.5" style="font-size: 0.7rem;"><%= current_user.respond_to?(:courses_count) ? current_user.courses_count : current_user.courses.count %></span>
                      <% end %>
                    </li>
                    <li>
                      <%= link_to my_students_enrollments_path, class: "dropdown-item py-2 small fw-semibold d-flex align-items-center justify-content-between" do %>
                        <span><i class="fa-solid fa-users me-2 text-secondary"></i> My Students</span>
                        <span class="badge bg-secondary text-white rounded-pill px-2 py-0.5" style="font-size: 0.7rem;"><%= Enrollment.joins(:course).where(courses: { user_id: current_user.id }).count %></span>
                      <% end %>
                    </li>
                  </ul>
                </li>
              <% end %>

              <!-- Admin Dropdown (Admin) -->
              <% if current_user.has_role?(:admin) %>
                <li class="nav-item dropdown" id="adminDropdown">
                  <a class="nav-link dropdown-toggle fw-bold px-3 text-secondary d-flex align-items-center gap-1" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fa-solid fa-cogs"></i> Admin
                  </a>
                  <ul class="dropdown-menu dropdown-menu-end shadow border border-light-subtle rounded-3 mt-2" style="min-width: 180px;">
                    <li>
                      <%= link_to users_path, class: "dropdown-item py-2 small fw-semibold d-flex align-items-center justify-content-between" do %>
                        <span><i class="fa-solid fa-users me-2 text-secondary"></i> Users</span>
                        <span class="badge bg-secondary text-white rounded-pill px-2 py-0.5" style="font-size: 0.7rem;"><%= User.count %></span>
                      <% end %>
                    </li>
                    <li>
                      <%= link_to enrollments_path, class: "dropdown-item py-2 small fw-semibold d-flex align-items-center justify-content-between" do %>
                        <span><i class="fa-solid fa-lock-open me-2 text-secondary"></i> Enrollments</span>
                        <span class="badge bg-secondary text-white rounded-pill px-2 py-0.5" style="font-size: 0.7rem;"><%= Enrollment.count %></span>
                      <% end %>
                    </li>
                    <li>
                      <%= link_to activity_path, class: "dropdown-item py-2 small fw-semibold" do %>
                        <i class="fa-solid fa-bell me-2 text-secondary"></i> Activity
                      <% end %>
                    </li>
                  </ul>
                </li>
              <% end %>
            <% end %>
          </ul>

          <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0 ms-lg-3">
            <% if user_signed_in? %>
              <span class="text-muted small d-none d-md-inline-block">
                <i class="fa-regular fa-user me-1"></i> <%= current_user.email %>
              </span>
              <%= link_to edit_user_registration_path, class: "btn btn-outline-secondary btn-sm px-3 py-2 fw-semibold rounded-pill" do %>
                <i class="fa-solid fa-gear"></i> Settings
              <% end %>
              <%= button_to destroy_user_session_path, method: :delete, class: "btn btn-outline-danger btn-sm px-3 py-2 fw-semibold rounded-pill d-inline-flex align-items-center gap-1" do %>
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Sign Out
              <% end %>
            <% else %>
              <%= link_to "Log In", new_user_session_path, class: "btn btn-link text-decoration-none text-dark fw-bold px-3" %>
              <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-primary btn-sm px-4 py-2 fw-bold rounded-pill" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <%= render "layouts/messages" %>

    <%= yield %>

    <%= render "layouts/footer" %>
  </body>
</html>
