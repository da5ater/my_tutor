<div class="container py-5 my-4">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
        <div class="text-center mb-4">
          <i class="fa-solid fa-lock fs-2 mb-3" style="color: #ff385c;"></i>
          <h2 class="fw-extrabold text-dark font-heading">Log in</h2>
          <p class="text-muted small">Welcome back! Please enter your details.</p>
        </div>

        <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="form-inputs mb-4">
            <%= f.input :email,
                        required: false,
                        autofocus: true,
                        placeholder: "yourname@example.com",
                        input_html: { autocomplete: "email", class: "form-control py-2.5" } %>
            <%= f.input :password,
                        required: false,
                        placeholder: "••••••••",
                        input_html: { autocomplete: "current-password", class: "form-control py-2.5" } %>
            
            <div class="d-flex align-items-center justify-content-between mt-3">
              <%= f.input :remember_me, as: :boolean, wrapper_html: { class: "mb-0" } if devise_mapping.rememberable? %>
            </div>
          </div>

          <div class="form-actions">
            <%= f.button :submit, "Log in", class: "btn btn-primary btn-lg w-100 py-2.5 fw-bold shadow-sm" %>
          </div>
        <% end %>

        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
