<div class="container py-5 my-4">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
        <div class="text-center mb-4">
          <i class="fa-solid fa-key fs-2 mb-3" style="color: #ff385c;"></i>
          <h2 class="fw-extrabold text-dark font-heading">Forgot your password?</h2>
          <p class="text-muted small">Enter your email and we'll send you reset instructions.</p>
        </div>

        <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
          <%= f.error_notification %>

          <div class="form-inputs mb-4">
            <%= f.input :email,
                        required: true,
                        autofocus: true,
                        placeholder: "yourname@example.com",
                        input_html: { autocomplete: "email", class: "form-control py-2.5" } %>
          </div>

          <div class="form-actions">
            <%= f.button :submit, "Send reset instructions", class: "btn btn-primary btn-lg w-100 py-2.5 fw-bold shadow-sm" %>
          </div>
        <% end %>

        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
