<div class="container py-5 my-4">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
        <div class="text-center mb-4">
          <i class="fa-solid fa-user-plus fs-2 mb-3" style="color: #ff385c;"></i>
          <h2 class="fw-extrabold text-dark font-heading">Sign up</h2>
          <p class="text-muted small">Create an account to start managing courses.</p>
        </div>

        <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <%= f.error_notification %>

          <div class="form-inputs mb-4">
            <%= f.input :email,
                        required: true,
                        autofocus: true,
                        placeholder: "yourname@example.com",
                        input_html: { autocomplete: "email", class: "form-control py-2.5" } %>
            <%= f.input :password,
                        required: true,
                        placeholder: "••••••••",
                        hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                        input_html: { autocomplete: "new-password", class: "form-control py-2.5" } %>
            <%= f.input :password_confirmation,
                        required: true,
                        placeholder: "••••••••",
                        input_html: { autocomplete: "new-password", class: "form-control py-2.5" } %>
          </div>

          <div class="form-actions">
            <%= f.button :submit, "Sign up", class: "btn btn-primary btn-lg w-100 py-2.5 fw-bold shadow-sm" %>
          </div>
        <% end %>

        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
