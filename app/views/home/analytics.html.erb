<% content_for :title, "Platform Analytics" %>
<% users_total = @users_count.to_i %>
<% enrollments_total = @enrollments_count.to_i %>
<% active_courses = @active_courses_count.to_i %>

<div class="container py-5 animate-fade-in" data-analytics-dashboard>
  <header class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-5">
    <div>
      <span class="analytics-eyebrow d-inline-flex align-items-center gap-2 mb-2">
        <i class="fa-solid fa-chart-line" aria-hidden="true"></i> Admin insights
      </span>
      <h1 class="display-6 fw-bold text-dark mb-2 font-heading">Platform analytics</h1>
      <p class="text-secondary mb-0">Understand acquisition, enrollment activity, and course demand.</p>
    </div>
    <span class="text-secondary small d-inline-flex align-items-center gap-2">
      <i class="fa-regular fa-clock" aria-hidden="true"></i>
      Updated <%= Time.current.strftime("%b %d, %Y at %I:%M %p") %>
    </span>
  </header>

  <section class="row g-3 mb-4" aria-label="Analytics summary">
    <div class="col-12 col-md-4">
      <div class="analytics-stat h-100 p-4 rounded-4">
        <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
          <span class="text-secondary small fw-semibold">Registered users</span>
          <span class="analytics-stat__icon"><i class="fa-solid fa-users" aria-hidden="true"></i></span>
        </div>
        <strong class="display-6 text-dark font-heading"><%= number_with_delimiter(users_total) %></strong>
        <span class="d-block text-secondary small mt-2">Accounts created over time</span>
      </div>
    </div>
    <div class="col-12 col-md-4">
      <div class="analytics-stat h-100 p-4 rounded-4">
        <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
          <span class="text-secondary small fw-semibold">Enrollments</span>
          <span class="analytics-stat__icon"><i class="fa-solid fa-user-graduate" aria-hidden="true"></i></span>
        </div>
        <strong class="display-6 text-dark font-heading"><%= number_with_delimiter(enrollments_total) %></strong>
        <span class="d-block text-secondary small mt-2">Course purchases recorded</span>
      </div>
    </div>
    <div class="col-12 col-md-4">
      <div class="analytics-stat h-100 p-4 rounded-4">
        <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
          <span class="text-secondary small fw-semibold">Courses with learners</span>
          <span class="analytics-stat__icon"><i class="fa-solid fa-book-open" aria-hidden="true"></i></span>
        </div>
        <strong class="display-6 text-dark font-heading"><%= number_with_delimiter(active_courses) %></strong>
        <span class="d-block text-secondary small mt-2">Courses represented in enrollment data</span>
      </div>
    </div>
  </section>

  <section class="row g-4">
    <div class="col-12 col-xl-7">
      <article class="analytics-chart-card h-100 p-4 p-md-5 rounded-4" data-chart="users-created">
        <div class="mb-4">
          <h2 class="h4 fw-bold text-dark mb-1">Users created per day</h2>
          <p class="text-secondary small mb-0">Daily account registrations across the platform.</p>
        </div>
        <%= line_chart "/charts/users_per_day",
          height: "320px",
          colors: ["#ff385c"],
          points: false,
          curve: false,
          library: { plugins: { legend: { display: false } } } %>
      </article>
    </div>

    <div class="col-12 col-xl-5">
      <article class="analytics-chart-card h-100 p-4 p-md-5 rounded-4" data-chart="enrollments-created">
        <div class="mb-4">
          <h2 class="h4 fw-bold text-dark mb-1">Enrollments created per day</h2>
          <p class="text-secondary small mb-0">Daily learner demand and purchasing activity.</p>
        </div>
        <%= column_chart "/charts/enrollments_per_day",
          height: "320px",
          colors: ["#222222"],
          library: { plugins: { legend: { display: false } } } %>
      </article>
    </div>

    <div class="col-12 col-xl-6">
      <article class="analytics-chart-card h-100 p-4 p-md-5 rounded-4" data-chart="course-popularity">
        <div class="mb-4">
          <h2 class="h4 fw-bold text-dark mb-1">Course popularity</h2>
          <p class="text-secondary small mb-0">Enrollment count by course title.</p>
        </div>
        <%= bar_chart "/charts/course_popularity",
          height: "360px",
          colors: ["#ff385c"],
          xtitle: "Enrollments",
          library: { plugins: { legend: { display: false } } } %>
      </article>
    </div>

    <div class="col-12 col-xl-6">
      <article class="analytics-chart-card h-100 p-4 p-md-5 rounded-4" data-chart="moneymakers">
        <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
          <div>
            <h2 class="h4 fw-bold text-dark mb-1">Top moneymakers</h2>
            <p class="text-secondary small mb-0">Recorded revenue by course title.</p>
          </div>
          <span class="analytics-stat__icon flex-shrink-0" aria-hidden="true">
            <i class="fa-solid fa-dollar-sign"></i>
          </span>
        </div>
        <%= bar_chart "/charts/moneymakers",
          height: "360px",
          colors: ["#222222"],
          prefix: "$",
          xtitle: "Revenue",
          empty: "No paid enrollments yet",
          library: { plugins: { legend: { display: false } } } %>
      </article>
    </div>

    <div class="col-12">
      <article class="analytics-chart-card p-4 p-md-5 rounded-4" data-chart="lesson-impressions">
        <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
          <div>
            <h2 class="h4 fw-bold text-dark mb-1">Lesson impressions</h2>
            <p class="text-secondary small mb-0">Total authorized lesson openings by lesson title.</p>
          </div>
          <span class="analytics-stat__icon flex-shrink-0" aria-hidden="true">
            <i class="fa-solid fa-eye"></i>
          </span>
        </div>
        <%= bar_chart "/charts/lesson_impressions",
          height: "360px",
          colors: ["#ff385c"],
          xtitle: "Impressions",
          empty: "No lesson impressions yet",
          library: { plugins: { legend: { display: false } } } %>
      </article>
    </div>
  </section>
</div>
