<% content_for :title, "Go Online Courses | Learn Anything on Your Schedule" %>
<div class="container py-5">
  <!-- Hero Jumbotron Section -->
  <div class="row align-items-center justify-content-between g-5 mb-5">
    <div class="col-lg-6 text-center text-lg-start">
      <span class="badge mb-3 py-2 px-3 fw-semibold shadow-sm" style="background-color: rgba(255, 56, 92, 0.1); color: #ff385c; border-radius: 50px; font-size: 0.85rem; letter-spacing: 0.5px;">
        <i class="fa-solid fa-sparkles me-1"></i> LEARN FROM HOME
      </span>
      <h1 class="display-4 fw-extrabold text-dark mb-3 font-heading" style="font-size: 3.25rem; line-height: 1.15;">
        Unlock Your Full Potential
      </h1>
      <p class="text-secondary mb-4 fs-5" style="line-height: 1.6; max-width: 540px;">
        Connect with verified private instructors for personalized, interactive sessions. Search our comprehensive catalog of tutoring programs.
      </p>

      <!-- Hero Search Form -->
      <% if current_user %>
        <div class="mt-4 mb-3" style="max-width: 520px;">
          <%= search_form_for @ransack_courses, as: :courses_search, url: courses_path, method: :get, html: { class: "d-flex align-items-center gap-2 bg-white p-2 rounded-pill shadow-sm border", role: "search" } do |f| %>
            <div class="d-flex align-items-center flex-grow-1 ps-3">
              <i class="fa-solid fa-magnifying-glass text-muted me-2"></i>
              <%= f.search_field :title_or_short_description_cont, placeholder: "What do you want to learn today?", class: "form-control border-0 bg-transparent p-0 small", style: "box-shadow: none; font-size: 0.95rem; color: #222;" %>
            </div>
            <%= f.submit "Search", class: "btn btn-primary rounded-pill px-4 py-2.5 fw-bold shadow-sm" %>
          <% end %>
        </div>
      <% end %>

      <!-- Older search form (commented out) -->
      <% if false %>
      <div class="mt-4 mb-3" style="max-width: 520px;">
        <%= form_with(url: courses_path, method: :get, local: true, class: "d-flex align-items-center gap-2 bg-white p-2 rounded-pill shadow-sm border") do |f| %>
          <div class="d-flex align-items-center flex-grow-1 ps-3">
            <i class="fa-solid fa-magnifying-glass text-muted me-2"></i>
            <%= f.text_field :title, placeholder: "What do you want to learn today?", class: "form-control border-0 bg-transparent p-0 small", style: "box-shadow: none; font-size: 0.95rem; color: #222;" %>
          </div>
          <%= f.submit "Search", class: "btn btn-primary rounded-pill px-4 py-2.5 fw-bold shadow-sm" %>
        <% end %>
      </div>
      <% end %>
    </div>
    
    <div class="col-lg-5 d-none d-lg-block">
      <!-- Creative visual dashboard widget -->
      <div class="card border border-light-subtle p-5 bg-white shadow-lg rounded-4 position-relative overflow-hidden">
        <div class="position-absolute top-0 end-0 bg-primary opacity-10 rounded-circle" style="width: 150px; height: 150px; transform: translate(50px, -50px);"></div>
        
        <h4 class="fw-extrabold text-dark font-heading mb-4"><i class="fa-solid fa-chart-line text-primary me-2" style="color: #ff385c !important;"></i> Tutor Dashboard</h4>
        
        <div class="d-flex align-items-center gap-3 mb-4 p-3 rounded-3" style="background-color: #f7f7f7;">
          <div class="bg-primary text-white d-flex align-items-center justify-content-center rounded-circle shadow-sm" style="width: 48px; height: 48px; background-color: #ff385c !important;">
            <i class="fa-solid fa-code"></i>
          </div>
          <div>
            <h6 class="mb-0 fw-bold text-dark">Ruby on Rails 8</h6>
            <span class="text-muted small">Next Session: Tomorrow, 10:00 AM</span>
          </div>
        </div>

        <div class="row g-3">
          <div class="col-6">
            <div class="border rounded-3 p-3 text-center bg-light bg-opacity-50">
              <span class="text-muted small d-block mb-1">Total Hours</span>
              <span class="h3 fw-bold text-dark font-heading">24h</span>
            </div>
          </div>
          <div class="col-6">
            <div class="border rounded-3 p-3 text-center bg-light bg-opacity-50">
              <span class="text-muted small d-block mb-1">Rating</span>
              <span class="h3 fw-bold text-dark font-heading"><i class="fa-solid fa-star small" style="color: var(--ink-color) !important;"></i> 4.9</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Statistics Banner -->
  <div class="card border-0 shadow-sm rounded-4 bg-white p-4 mb-5 border-top border-4 border-primary" style="border-top-color: #ff385c !important;">
    <div class="row text-center g-4">
      <div class="col-md-3 border-end border-light-subtle">
        <h3 class="fw-extrabold text-dark font-heading mb-1"><%= @courses_count || 0 %></h3>
        <span class="text-muted small text-uppercase fw-bold"><i class="fa-solid fa-book-open text-primary me-1" style="color: #ff385c !important;"></i> Courses</span>
      </div>
      <div class="col-md-3 border-end border-light-subtle">
        <h3 class="fw-extrabold text-dark font-heading mb-1"><%= @instructors_count || 0 %></h3>
        <span class="text-muted small text-uppercase fw-bold"><i class="fa-solid fa-chalkboard-user text-primary me-1" style="color: #ff385c !important;"></i> Instructors</span>
      </div>
      <div class="col-md-3 border-end border-light-subtle">
        <h3 class="fw-extrabold text-dark font-heading mb-1"><%= @users_count || 0 %></h3>
        <span class="text-muted small text-uppercase fw-bold"><i class="fa-solid fa-users text-primary me-1" style="color: #ff385c !important;"></i> Students</span>
      </div>
      <div class="col-md-3">
        <h3 class="fw-extrabold text-success font-heading mb-1">Active</h3>
        <span class="text-muted small text-uppercase fw-bold"><i class="fa-solid fa-circle-check text-success me-1"></i> Status</span>
      </div>
    </div>
  </div>

  <hr class="my-5 opacity-25">

  <!-- Continue Learning Section -->
  <% if @purchased_courses.present? %>
    <div class="mb-5 animate-fade-in">
      <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
          <h2 class="fw-extrabold text-dark font-heading mb-1"><i class="fa-solid fa-graduation-cap text-primary" style="color: #ff385c !important;"></i> Continue Learning</h2>
          <p class="text-muted mb-0 small">Pick up where you left off in your courses.</p>
        </div>
        <%= link_to purchased_courses_path, class: "text-decoration-none fw-bold text-primary small d-flex align-items-center gap-1" do %>
          My Courses <i class="fa-solid fa-arrow-right"></i>
        <% end %>
      </div>
      
      <div class="row row-cols-1 row-cols-md-3 g-4">
        <% @purchased_courses.each do |course| %>
          <div class="col">
            <%= render course %>
          </div>
        <% end %>
      </div>
    </div>
    <hr class="my-5 opacity-25">
  <% end %>

  <!-- Popular Courses Section -->
  <div class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <h2 class="fw-extrabold text-dark font-heading mb-1"><i class="fa-solid fa-chart-line text-primary" style="color: #ff385c !important;"></i> Popular Courses</h2>
        <p class="text-muted mb-0 small">Our most applied programs with active students.</p>
      </div>
      <%= link_to courses_path, class: "text-decoration-none fw-bold text-primary small d-flex align-items-center gap-1" do %>
        See all <i class="fa-solid fa-arrow-right"></i>
      <% end %>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% if @popular_courses&.any? %>
        <% @popular_courses.each do |course| %>
          <div class="col">
            <%= render course %>
          </div>
        <% end %>
      <% else %>
        <div class="col-12 text-center py-4 text-muted">
          No popular courses found.
        </div>
      <% end %>
    </div>
  </div>

  <hr class="my-5 opacity-25">

  <!-- Top Rated Courses Section -->
  <div class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <h2 class="fw-extrabold text-dark font-heading mb-1"><i class="fa-solid fa-star text-primary" style="color: #ff385c !important;"></i> Top Rated Courses</h2>
        <p class="text-muted mb-0 small">Programs reviewed highly by our learning community.</p>
      </div>
      <%= link_to courses_path, class: "text-decoration-none fw-bold text-primary small d-flex align-items-center gap-1" do %>
        See all <i class="fa-solid fa-arrow-right"></i>
      <% end %>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% if @top_rated_courses&.any? %>
        <% @top_rated_courses.each do |course| %>
          <div class="col">
            <%= render course %>
          </div>
        <% end %>
      <% else %>
        <div class="col-12 text-center py-4 text-muted">
          No rated courses found.
        </div>
      <% end %>
    </div>
  </div>

  <hr class="my-5 opacity-25">

  <!-- Latest Courses Section -->
  <div class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <h2 class="fw-extrabold text-dark font-heading mb-1"><i class="fa-solid fa-clock text-primary" style="color: #ff385c !important;"></i> Latest Courses</h2>
        <p class="text-muted mb-0 small">The most recently published tutoring programs.</p>
      </div>
      <%= link_to courses_path, class: "text-decoration-none fw-bold text-primary small d-flex align-items-center gap-1" do %>
        See all <i class="fa-solid fa-arrow-right"></i>
      <% end %>
    </div>
    
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% if @latest_courses&.any? %>
        <% @latest_courses.each do |course| %>
          <div class="col">
            <%= render course %>
          </div>
        <% end %>
      <% else %>
        <div class="col-12 text-center py-4 text-muted">
          No courses published yet.
        </div>
      <% end %>
    </div>
  </div>

  <hr class="my-5 opacity-25">

  <!-- Reviews Section -->
  <div class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <h2 class="fw-extrabold text-dark font-heading mb-1"><i class="fa-solid fa-comment text-primary" style="color: #ff385c !important;"></i> What our students have to say</h2>
        <p class="text-muted mb-0 small">The latest reviews left by our student community.</p>
      </div>
    </div>
    
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% if @latest_good_reviews&.any? %>
        <% @latest_good_reviews.each do |enrollment| %>
          <div class="col">
            <%= render 'enrollments/enrollment', enrollment: enrollment %>
          </div>
        <% end %>
      <% else %>
        <div class="col-12 text-center py-4 text-muted">
          No reviews available yet.
        </div>
      <% end %>
    </div>
  </div>
</div>

