<% content_for :title, "Activity" %>
<div class="container py-5" style="max-width: 960px;">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h3 class="fw-bold text-dark font-heading mb-1">
        Activity Log
        <span class="badge bg-info text-white ms-2" style="font-size: 0.8rem; vertical-align: middle;"><%= @activities.count %></span>
      </h3>
      <p class="text-secondary mb-0 small">Real-time actions and changes across the tutor platform.</p>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
    <div class="list-group list-group-flush">
      <% if @activities.any? %>
        <% @activities.each do |activity| %>
          <% 
            action_verb = case activity.key&.split('.')&.last
                          when 'create' then 'created'
                          when 'update' then 'updated'
                          when 'destroy' then 'deleted'
                          else activity.key&.split('.')&.last || 'performed action'
                          end
            
            icon_class, bg_color, text_color = case activity.key&.split('.')&.last
                                               when 'create' then ['fa-plus', 'rgba(46, 204, 113, 0.1)', '#2ecc71']
                                               when 'update' then ['fa-pen-to-square', 'rgba(52, 152, 219, 0.1)', '#3498db']
                                               when 'destroy' then ['fa-trash-can', 'rgba(231, 76, 60, 0.1)', '#e74c3c']
                                               else ['fa-circle-info', 'rgba(149, 165, 166, 0.1)', '#95a5a6']
                                               end
          %>
          <div class="list-group-item p-4 border-bottom" style="border-color: #f2f2f2 !important;">
            <div class="d-flex align-items-center gap-3">
              <!-- Elegant Circular Indicator Icon -->
              <div class="rounded-circle d-flex align-items-center justify-content-center" 
                   style="width: 44px; height: 44px; flex-shrink: 0; background-color: <%= bg_color %>; color: <%= text_color %>;">
                <i class="fa-solid <%= icon_class %> fs-5"></i>
              </div>
              
              <!-- Prettified Activity Message -->
              <div class="flex-grow-1">
                <div class="text-dark fs-6" style="line-height: 1.4;">
                  <% if activity.owner %>
                    <span class="fw-bold text-dark"><%= activity.owner.username.capitalize %></span>
                  <% else %>
                    <span class="text-muted italic">An anonymous user</span>
                  <% end %>
                  <% 
                    trackable_name = case activity.trackable_type
                                     when 'Course' then 'course'
                                     when 'Lesson' then 'lesson'
                                     else activity.trackable_type&.downcase || 'record'
                                     end
                  %>
                  <span class="text-secondary mx-1"><%= action_verb %> the <%= trackable_name %></span>
                  <% if activity.trackable %>
                    <%
                      trackable_path = if activity.trackable.is_a?(Lesson)
                                         activity.trackable.course ? course_lesson_path(activity.trackable.course, activity.trackable) : nil
                                       else
                                         activity.trackable
                                       end
                    %>
                    <% if trackable_path %>
                      <%= link_to activity.trackable.to_s, trackable_path, class: "fw-bold text-decoration-none hover-underline", style: "color: #ff385c !important;" %>
                    <% else %>
                      <span class="fw-bold text-dark"><%= activity.trackable.to_s %></span>
                    <% end %>
                  <% else %>
                    <span class="fw-semibold text-secondary italic">a <%= trackable_name %> (ID: <%= activity.trackable_id %> - deleted)</span>
                  <% end %>
                </div>
                
                <div class="text-muted small mt-1 d-flex flex-wrap align-items-center gap-2" style="font-size: 0.75rem;">
                  <span class="d-flex align-items-center gap-1">
                    <i class="fa-regular fa-clock"></i> <%= time_ago_in_words(activity.created_at) %> ago
                  </span>
                  <span>•</span>
                  <span><%= activity.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
                  <span>•</span>
                  <span class="badge bg-light text-secondary border rounded-pill px-2 py-1">ID: #<%= activity.id %></span>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-5 text-muted">
          <i class="fa-solid fa-bell-slash fa-2x mb-3 d-block opacity-40"></i>
          <h5 class="fw-bold text-dark font-heading">No Activity Recorded</h5>
          <p class="small mb-0">Activities will show up here as courses are managed.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
  .hover-underline:hover {
    text-decoration: underline !important;
  }
</style>
