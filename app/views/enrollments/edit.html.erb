<div class="container py-5" style="max-width: 720px;">
  <% content_for :title, "Add/Edit Review" %>

  <div class="mb-4">
    <% if @enrollment.course %>
      <%= link_to course_path(@enrollment.course), class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
        <i class="fa-solid fa-arrow-left"></i> Back to <%= @enrollment.course.title %>
      <% end %>
    <% else %>
      <%= link_to enrollments_path, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
        <i class="fa-solid fa-arrow-left"></i> Back to Enrollments
      <% end %>
    <% end %>
  </div>

  <div class="card border border-light-subtle shadow-sm rounded-4 overflow-hidden bg-white">
    <div style="height: 6px; background-color: #ff385c;"></div>

    <!-- Card header with Lock Open Icon -->
    <div class="card-header bg-white border-bottom p-4 d-flex align-items-center gap-3">
      <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border" style="width: 48px; height: 48px; color: #ff385c; flex-shrink: 0;">
        <i class="fa-solid fa-star fs-4"></i>
      </div>
      <div>
        <h4 class="fw-extrabold text-dark m-0 font-heading">
          Add/Edit Review
        </h4>
        <small class="text-secondary"><%= @enrollment.course.title if @enrollment.course %></small>
      </div>
    </div>

    <!-- Card body with Form -->
    <div class="card-body p-4 p-md-5">
      <%= render "form", enrollment: @enrollment %>
    </div>

    <!-- Card footer with links -->
    <div class="card-footer bg-light border-top p-4 d-flex justify-content-between">
      <%= link_to @enrollment, class: "btn btn-outline-secondary px-3 py-2 fw-semibold rounded-2" do %>
        <i class="fa-solid fa-eye"></i> Show Review
      <% end %>
      <% if @enrollment.course %>
        <%= link_to course_path(@enrollment.course), class: "btn btn-outline-secondary px-3 py-2 fw-semibold rounded-2" do %>
          Back to Course
        <% end %>
      <% end %>
    </div>
  </div>
</div>
