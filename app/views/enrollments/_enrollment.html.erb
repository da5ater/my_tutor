<div class="card border border-light-subtle shadow-sm rounded-4 overflow-hidden bg-white mb-4 animate-fade-in" id="<%= dom_id enrollment %>">
  <!-- Accent top bar (voltage color) -->
  <div style="height: 6px; background-color: #ff385c;"></div>

  <!-- Card Header -->
  <div class="card-header bg-white border-bottom p-4 d-flex flex-wrap align-items-center justify-content-between gap-3">
    <div class="d-flex align-items-center gap-2">
      <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border" style="width: 36px; height: 36px; flex-shrink: 0;">
        <i class="fa-solid fa-user text-secondary" style="font-size: 0.9rem;"></i>
      </div>
      <% if enrollment.user %>
        <%= link_to enrollment.user.username.capitalize, user_path(enrollment.user), class: "text-decoration-none text-dark hover-underline fw-bold" %>
      <% else %>
        <span class="text-muted italic">Unknown user</span>
      <% end %>
    </div>

    <div class="text-muted small d-flex align-items-center gap-1">
      <i class="fa-regular fa-clock"></i> <%= time_ago_in_words(enrollment.updated_at) %> ago
    </div>

    <% if enrollment.course %>
      <div class="d-flex align-items-center gap-1 text-truncate" style="max-width: 250px;">
        <i class="fa-solid fa-graduation-cap text-primary" style="color: #ff385c !important;"></i>
        <%= link_to enrollment.course.title, course_path(enrollment.course), class: "text-decoration-none text-dark hover-underline fw-semibold small text-truncate" %>
      </div>
    <% end %>
  </div>

  <!-- Card Body -->
  <div class="card-body p-4">
    <div class="d-flex align-items-center gap-2 mb-3">
      <% if enrollment.rating.present? %>
        <span class="text-warning fs-5"><i class="fa-solid fa-star"></i></span>
        <span class="fw-bold fs-5 text-dark"><%= enrollment.rating %>/5</span>
      <% else %>
        <span class="text-muted small italic">Not rated yet</span>
      <% end %>
    </div>
    
    <% if enrollment.review.present? %>
      <div class="d-flex align-items-start gap-2 text-secondary fs-5" style="line-height: 1.5;">
        <i class="fa-solid fa-comment mt-1 text-muted" style="font-size: 1rem;"></i>
        <div><%= enrollment.review %></div>
      </div>
    <% else %>
      <p class="text-muted italic mb-0 small">No review comments provided.</p>
    <% end %>
  </div>

  <!-- Card Footer -->
  <% if current_user && policy(enrollment).edit? %>
    <div class="card-footer bg-light border-top p-4 d-flex justify-content-end">
      <%= link_to edit_enrollment_path(enrollment), class: "btn btn-outline-primary px-4 py-2 fw-bold rounded-pill" do %>
        <i class="fa-solid fa-pen-to-square me-1"></i> Edit Review
      <% end %>
    </div>
  <% end %>
</div>
