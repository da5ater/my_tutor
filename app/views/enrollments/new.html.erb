<div class="container py-5" style="max-width: 720px;">
  <% if @course.present? %>
    <% content_for :title, "Enroll in #{@course.title}" %>

    <div class="mb-4">
      <%= link_to course_path(@course), class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
        <i class="fa-solid fa-arrow-left"></i> Back to <%= @course.title %>
      <% end %>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
      <!-- Card header with Graduation Cap Icon -->
      <div class="card-header bg-white border-bottom p-4 d-flex align-items-center gap-3">
        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; color: #ff385c;">
          <i class="fa-solid fa-graduation-cap fs-4"></i>
        </div>
        <div>
          <h4 class="fw-extrabold text-dark m-0 font-heading">
            Buy Course
          </h4>
          <small class="text-secondary"><%= @course.title %></small>
        </div>
      </div>

      <!-- Card body with pay confirmation -->
      <div class="card-body p-4 p-md-5 text-center">
        <h5 class="fw-bold mb-3 text-secondary">You are enrolling in:</h5>
        <h2 class="display-6 fw-extrabold text-dark mb-4 font-heading"><%= @course.title %></h2>
        
        <p class="text-muted mb-5">By enrolling, you will gain lifetime access to all lessons and materials of this course.</p>

        <%= form_with url: course_enrollments_path(@course), local: true do |f| %>
          <% if @course.price > 0 %>
            <%= f.submit "Pay #{number_to_currency(@course.price, precision: 0)}", class: "btn btn-success btn-lg w-100 py-3 fw-extrabold shadow rounded-3 fs-5" %>
          <% else %>
            <%= f.submit "Enroll for Free", class: "btn btn-success btn-lg w-100 py-3 fw-extrabold shadow rounded-3 fs-5" %>
          <% end %>
        <% end %>
      </div>

      <!-- Card footer -->
      <div class="card-footer bg-light border-top p-4 d-flex justify-content-end">
        <%= link_to course_path(@course), class: "btn btn-outline-secondary px-3 py-2 fw-semibold rounded-2" do %>
          Cancel
        <% end %>
      </div>
    </div>
  <% else %>
    <% content_for :title, "New Enrollment" %>

    <div class="mb-4">
      <%= link_to enrollments_path, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
        <i class="fa-solid fa-arrow-left"></i> Back to Enrollments
      <% end %>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
      <!-- Card header with Lock Open Icon -->
      <div class="card-header bg-white border-bottom p-4 d-flex align-items-center gap-3">
        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; color: #ff385c;">
          <i class="fa-solid fa-lock-open fs-4"></i>
        </div>
        <div>
          <h4 class="fw-extrabold text-dark m-0 font-heading">
            New Enrollment
          </h4>
          <small class="text-secondary">Enroll a student in a course and set initial ratings.</small>
        </div>
      </div>

      <!-- Card body with Form -->
      <div class="card-body p-4 p-md-5">
        <%= render "form", enrollment: @enrollment %>
      </div>

      <!-- Card footer with links -->
      <div class="card-footer bg-light border-top p-4 d-flex justify-content-end">
        <%= link_to enrollments_path, class: "btn btn-outline-secondary px-3 py-2 fw-semibold rounded-2" do %>
          Back to Enrollments
        <% end %>
      </div>
    </div>
  <% end %>
</div>
