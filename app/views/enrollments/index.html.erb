<div class="container py-5 animate-fade-in">
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 d-flex align-items-center" role="alert">
      <i class="fa-solid fa-circle-check me-2"></i>
      <div><%= notice %></div>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <% current_action_title = action_name == 'index' ? 'All' : action_name.humanize %>
  <% content_for :title, "#{current_action_title} Enrollments" %>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h3 class="fw-bold text-dark mb-1 font-heading">
        <%= current_action_title %> Enrollments
        <span class="badge bg-info text-white"><%= @enrollments.count %></span>
      </h3>
      <p class="text-secondary mb-0">Browse, search, and sort all student enrollments and ratings.</p>
    </div>
  </div>

  <% if @q.present? %>
    <%= search_form_for @q, url: (@ransack_path || enrollments_path), html: { class: "mb-4" } do |f| %>
      <div class="card border border-light-subtle shadow-sm rounded-4 bg-white p-4">
        <div class="row g-3">
          <div class="col-12 col-md-3">
            <label for="q_review_cont" class="form-label fw-semibold small text-secondary">Review contains</label>
            <%= text_field_tag "q[review_cont]", params.dig(:q, :review_cont), id: "q_review_cont", placeholder: "Search review text...", class: "form-control rounded-pill border-light-subtle py-2 px-3 small" %>
          </div>
          <div class="col-12 col-md-2">
            <label for="q_rating_eq" class="form-label fw-semibold small text-secondary">Rating equals</label>
            <%= select_tag "q[rating_eq]", options_for_select([["Any rating", ""]] + (1..5).map { |r| [r, r] }, params.dig(:q, :rating_eq)), id: "q_rating_eq", class: "form-select rounded-pill border-light-subtle py-2 px-3 small" %>
          </div>
          <div class="col-12 col-md-3">
            <label for="q_user_email_cont" class="form-label fw-semibold small text-secondary">Student email contains</label>
            <%= text_field_tag "q[user_email_cont]", params.dig(:q, :user_email_cont), id: "q_user_email_cont", placeholder: "Student email...", class: "form-control rounded-pill border-light-subtle py-2 px-3 small" %>
          </div>
          <div class="col-12 col-md-2">
            <label for="q_course_title_cont" class="form-label fw-semibold small text-secondary">Course title contains</label>
            <%= text_field_tag "q[course_title_cont]", params.dig(:q, :course_title_cont), id: "q_course_title_cont", placeholder: "Course title...", class: "form-control rounded-pill border-light-subtle py-2 px-3 small" %>
          </div>
          <div class="col-12 col-md-2">
            <label for="q_price_eq" class="form-label fw-semibold small text-secondary">Price equals</label>
            <%= number_field_tag "q[price_eq]", params.dig(:q, :price_eq), id: "q_price_eq", placeholder: "Price...", class: "form-control rounded-pill border-light-subtle py-2 px-3 small" %>
          </div>
        </div>
        <div class="d-flex justify-content-end gap-2 mt-4">
          <%= link_to (@ransack_path || enrollments_path), class: "btn btn-outline-secondary px-4 py-2 rounded-pill fw-semibold small d-inline-flex align-items-center gap-1" do %>
            <i class="fa-solid fa-rotate"></i> Reset
          <% end %>
          <%= f.button type: :submit, class: "btn btn-primary px-4 py-2 rounded-pill fw-semibold small d-inline-flex align-items-center gap-1" do %>
            <i class="fa-solid fa-magnifying-glass"></i> Search
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
    <div class="table-responsive">
      <table class="table table-striped table-bordered table-hover align-middle mb-0">
        <thead class="table-light border-bottom">
          <tr>
            <th class="px-4 py-3 text-secondary font-heading fw-bold">
              <% if @q.present? %>
                <%= sort_link(@q, :created_at, raw("<i class='fa-solid fa-clock'></i> Bought At"), class: "text-decoration-none text-secondary hover-underline") %>
              <% else %>
                <i class="fa-solid fa-clock"></i> Bought At
              <% end %>
            </th>
            <th class="px-4 py-3 text-secondary font-heading fw-bold">ID</th>
            <th class="px-4 py-3 text-secondary font-heading fw-bold">
              <% if @q.present? %>
                <%= sort_link(@q, :user_email, raw("<i class='fa-solid fa-user'></i> Student"), class: "text-decoration-none text-secondary hover-underline") %>
              <% else %>
                <i class="fa-solid fa-user"></i> Student
              <% end %>
            </th>
            <th class="px-4 py-3 text-secondary font-heading fw-bold">
              <% if @q.present? %>
                <%= sort_link(@q, :course_title, raw("<i class='fa-solid fa-graduation-cap'></i> Course"), class: "text-decoration-none text-secondary hover-underline") %>
              <% else %>
                <i class="fa-solid fa-graduation-cap"></i> Course
              <% end %>
            </th>
            <th class="px-4 py-3 text-secondary font-heading fw-bold">
              <i class="fa-solid fa-chart-simple"></i> Progress
            </th>
            <th class="px-4 py-3 text-secondary font-heading fw-bold">
              <% if @q.present? %>
                <%= sort_link(@q, :price, raw("<i class='fa-solid fa-dollar-sign'></i> Price"), class: "text-decoration-none text-secondary hover-underline") %>
              <% else %>
                <i class="fa-solid fa-dollar-sign"></i> Price
              <% end %>
            </th>
            <th class="px-4 py-3 text-secondary font-heading fw-bold">
              <% if @q.present? %>
                <%= sort_link(@q, :updated_at, "Reviewed On", class: "text-decoration-none text-secondary hover-underline") %>
              <% else %>
                Reviewed On
              <% end %>
            </th>
            <th class="px-4 py-3 text-secondary font-heading fw-bold">
              <% if @q.present? %>
                <%= sort_link(@q, :rating, raw("<i class='fa-solid fa-star' style='color: var(--ink-color);'></i> Rating"), class: "text-decoration-none text-secondary hover-underline") %>
              <% else %>
                <i class="fa-solid fa-star" style="color: var(--ink-color);"></i> Rating
              <% end %>
            </th>
            <th class="px-4 py-3 text-secondary font-heading fw-bold"><i class="fa-solid fa-comment"></i> Review</th>
            <th class="px-4 py-3 text-secondary font-heading fw-bold text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if @enrollments.any? %>
            <% @enrollments.each do |enrollment| %>
              <tr id="<%= dom_id enrollment %>">
                <td class="px-4 py-3 small text-muted">
                  <%= enrollment.created_at.strftime("%d-%b-%Y %H:%M") if enrollment.created_at %>
                </td>
                <td class="px-4 py-3 fw-semibold text-muted">#<%= enrollment.id %></td>
                <td class="px-4 py-3">
                  <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border" style="width: 32px; height: 32px; flex-shrink: 0;">
                      <i class="fa-solid fa-circle-user text-secondary"></i>
                    </div>
                    <div class="text-truncate" style="max-width: 150px;">
                      <% if enrollment.user %>
                        <%= link_to enrollment.user.email, user_path(enrollment.user), class: "text-decoration-none text-dark hover-underline fw-semibold" %>
                      <% else %>
                        <span class="text-muted italic">Unknown user</span>
                      <% end %>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <% if enrollment.course %>
                    <%= link_to enrollment.course.title, course_path(enrollment.course), class: "text-decoration-none text-dark hover-underline fw-semibold" %>
                  <% else %>
                    <span class="text-muted italic">Deleted course</span>
                  <% end %>
                </td>
                <td class="px-4 py-3" style="min-width: 170px;">
                  <% if enrollment.course && enrollment.user %>
                    <%= render "courses/progress", course: enrollment.course, user: enrollment.user, compact: true %>
                  <% else %>
                    <span class="text-muted small">Unavailable</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 fw-bold text-dark">
                  <%= number_to_currency(enrollment.price, precision: 0) %>
                </td>
                <td class="px-4 py-3 small">
                  <% if enrollment.rating.present? %>
                    <%= enrollment.updated_at.strftime("%d-%b-%Y %H:%M") if enrollment.updated_at %>
                  <% else %>
                    <span class="text-warning" title="Unreviewed"><i class="fa-solid fa-clock"></i></span>
                  <% end %>
                </td>
                <td class="px-4 py-3">
                  <% if enrollment.rating.present? %>
                    <span class="fw-bold text-dark"><i class="fa-solid fa-star" style="color: var(--ink-color);"></i> <%= enrollment.rating %></span>
                  <% else %>
                    <span class="text-muted small">-</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-secondary text-truncate small" style="max-width: 150px;" title="<%= enrollment.review %>">
                  <% if enrollment.review.present? %>
                    <i class="fa-solid fa-comment text-secondary"></i> <%= enrollment.review %>
                  <% else %>
                    <span class="text-muted">-</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-end">
                  <div class="d-inline-flex gap-2">
                    <%= link_to enrollment, class: "btn btn-sm btn-outline-secondary d-flex align-items-center gap-1 px-3 py-1.5 rounded-2" do %>
                      See Review
                    <% end %>
                    <% if policy(enrollment).edit? %>
                      <%= link_to edit_enrollment_path(enrollment), class: "btn btn-sm btn-outline-primary d-flex align-items-center gap-1 px-3 py-1.5 rounded-2" do %>
                        Add/Edit Review
                      <% end %>
                    <% end %>
                    <% if policy(enrollment).destroy? %>
                      <%= button_to enrollment, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this enrollment?" }, class: "btn btn-sm btn-outline-danger d-flex align-items-center gap-1 px-3 py-1.5 rounded-2" do %>
                        Delete Enrollment
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="10" class="text-center py-5 text-muted">
                <i class="fa-solid fa-magnifying-glass fa-2x mb-3 d-block opacity-50"></i>
                No enrollments found matching the search criteria.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @pagy.present? && @pagy.pages > 1 %>
    <div class="mt-4 d-flex justify-content-center">
      <%== @pagy.series_nav(:bootstrap) %>
    </div>
  <% end %>

  <div class="mt-4">
    <%= link_to root_path, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
      <i class="fa-solid fa-arrow-left"></i> Back to Home
    <% end %>
  </div>
</div>
