<div class="container py-5" style="max-width: 720px;">
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 d-flex align-items-center" role="alert">
      <i class="fa-solid fa-circle-check me-2"></i>
      <div><%= notice %></div>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <% content_for :title, "Enrollment Details" %>

  <div class="mb-4">
    <%= link_to enrollments_path, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
      <i class="fa-solid fa-arrow-left"></i> Back to Enrollments
    <% end %>
  </div>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
    <!-- Card header with Lock Open Icon -->
    <div class="card-header bg-white border-bottom p-4 d-flex align-items-center gap-3">
      <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; color: #ff385c;">
        <i class="fa-solid fa-lock-open fs-4"></i>
      </div>
      <div>
        <h4 class="fw-extrabold text-dark m-0 font-heading">
          Enrollment Details
        </h4>
        <small class="text-secondary">Registered on <%= @enrollment.created_at.strftime('%B %d, %Y') if @enrollment.created_at %></small>
      </div>
    </div>

    <!-- Card body with Details -->
    <div class="card-body p-4 p-md-5">
      <div class="row g-4">
        <div class="col-12 border-bottom pb-3">
          <span class="text-muted small d-block mb-1 text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">Student / User</span>
          <div class="d-flex align-items-center gap-2">
            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border" style="width: 36px; height: 36px; flex-shrink: 0;">
              <i class="fa-solid fa-user text-secondary"></i>
            </div>
            <% if @enrollment.user %>
              <%= link_to @enrollment.user.email, user_path(@enrollment.user), class: "text-decoration-none text-dark hover-underline fw-bold fs-5" %>
            <% else %>
              <span class="text-muted italic">Unknown user</span>
            <% end %>
          </div>
        </div>

        <div class="col-12 border-bottom pb-3">
          <span class="text-muted small d-block mb-1 text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">Course</span>
          <% if @enrollment.course %>
            <%= link_to @enrollment.course.title, course_path(@enrollment.course), class: "text-decoration-none text-dark hover-underline fw-bold fs-5 font-heading" %>
          <% else %>
            <span class="text-muted italic">Deleted course</span>
          <% end %>
        </div>

        <div class="col-12 col-md-6 border-bottom pb-3">
          <span class="text-muted small d-block mb-1 text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">Price Paid</span>
          <span class="fs-4 fw-extrabold text-dark"><%= number_to_currency(@enrollment.price, precision: 0) %></span>
        </div>

        <div class="col-12 col-md-6 border-bottom pb-3">
          <span class="text-muted small d-block mb-1 text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">Rating</span>
          <% if @enrollment.rating.present? %>
            <span class="fs-5 text-warning fw-bold"><i class="fa-solid fa-star"></i> <%= @enrollment.rating %> / 5</span>
          <% else %>
            <span class="text-muted small">Not rated yet</span>
          <% end %>
        </div>

        <div class="col-12 pb-3">
          <span class="text-muted small d-block mb-1 text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">Review</span>
          <p class="text-secondary fs-5" style="line-height: 1.5;"><%= @enrollment.review.presence || "No review has been provided." %></p>
        </div>
      </div>
    </div>

    <!-- Card footer with actions -->
    <div class="card-footer bg-light border-top p-4 d-flex justify-content-between align-items-center">
      <%= link_to edit_enrollment_path(@enrollment), class: "btn btn-outline-primary px-4 py-2 fw-bold rounded-pill" do %>
        <i class="fa-solid fa-pen-to-square me-1"></i> Edit Enrollment
      <% end %>
      
      <%= button_to @enrollment, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this enrollment?" }, class: "btn btn-outline-danger px-4 py-2 fw-semibold rounded-pill d-inline-flex align-items-center gap-1" do %>
        <i class="fa-solid fa-trash small"></i> Delete Enrollment
      <% end %>
    </div>
  </div>
</div>
