<div class="container py-5" style="max-width: 720px;">
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 d-flex align-items-center" role="alert">
      <i class="fa-solid fa-circle-check me-2"></i>
      <div><%= notice %></div>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <% content_for :title, "Enrollment Review" %>

  <div class="mb-4">
    <% if @enrollment.course %>
      <%= link_to course_path(@enrollment.course), class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
        <i class="fa-solid fa-arrow-left"></i> Back to <%= @enrollment.course.title %>
      <% end %>
    <% else %>
      <%= link_to enrollments_path, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
        <i class="fa-solid fa-arrow-left"></i> Back to Enrollments
      <% end %>
    <% end %>
  </div>

  <%= render @enrollment %>
</div>
