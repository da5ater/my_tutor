<%= simple_form_for(@enrollment, html: { class: "needs-validation" }) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs mb-4 d-flex flex-column gap-3">
    <% if @enrollment.new_record? %>
      <%= f.association :course, input_html: { class: "form-select py-2.5" } %>
      <%= f.association :user, label_method: :email, input_html: { class: "form-select py-2.5" } %>
    <% end %>

    <div class="mb-2">
      <%= f.input :rating, 
                  collection: 1..5, 
                  as: :radio_buttons,
                  item_wrapper_class: 'form-check-inline me-3',
                  input_html: { class: "form-check-input" },
                  label_html: { class: "fw-bold d-block mb-2 font-heading text-dark" } %>
    </div>

    <%= f.input :review, placeholder: "Write your review here...", input_html: { class: "form-control py-2.5", rows: 4 } %>
  </div>

  <div class="form-actions">
    <%= f.button :submit, "Save Review", class: "btn btn-primary w-100 py-2.5 fw-bold shadow-sm rounded-3" %>
  </div>
<% end %>
