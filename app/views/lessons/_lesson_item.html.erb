<% can_view_lesson = current_user.present? && defined?(LessonPolicy) && policy(lesson).show? %>
<% viewed_by_current_user = can_view_lesson && lesson.viewed_by?(current_user) %>

<div class="card border border-light-subtle rounded-3 p-3 mb-3 shadow-none hover-shadow-sm transition-all" id="<%= dom_id lesson %>">
  <div class="d-flex justify-content-between align-items-start gap-3">
    <div class="text-truncate flex-grow-1">
      <h5 class="fw-bold fs-6 mb-1 text-truncate">
        <%= link_to lesson.title, [lesson.course, lesson], class: "text-decoration-none text-dark hover-text-primary" %>
      </h5>

      <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
        <% if can_view_lesson %>
          <% if viewed_by_current_user %>
            <span class="d-inline-flex align-items-center gap-1 rounded-pill border px-2 py-1 small fw-semibold text-dark bg-light" aria-label="Lesson viewed">
              <i class="fa-solid fa-circle-check text-success" aria-hidden="true"></i>
              Viewed
            </span>
          <% else %>
            <span class="d-inline-flex align-items-center gap-1 rounded-pill border px-2 py-1 small fw-semibold text-secondary bg-white" aria-label="Lesson not viewed">
              <i class="fa-regular fa-circle text-secondary" aria-hidden="true"></i>
              Not viewed
            </span>
          <% end %>

          <span class="text-secondary small d-inline-flex align-items-center gap-1">
          <i class="fa-regular fa-circle-play" aria-hidden="true"></i>
            Open to view content
          </span>
        <% else %>
          <span class="d-inline-flex align-items-center gap-1 rounded-pill border px-2 py-1 small fw-semibold text-secondary bg-light">
            <i class="fa-solid fa-lock small" aria-hidden="true"></i>
            Content locked
          </span>
        <% end %>
      </div>
    </div>
    
    <div class="d-flex gap-1 flex-shrink-0">
      <% if can_view_lesson %>
        <%= link_to [lesson.course, lesson], class: "btn btn-sm btn-outline-secondary d-flex align-items-center justify-content-center px-2 py-1.5 rounded-2" do %>
          <i class="fa-solid fa-eye" style="font-size: 0.8rem;"></i>
        <% end %>
      <% end %>
      <% if current_user && defined?(LessonPolicy) && policy(lesson).edit? %>
        <%= link_to edit_course_lesson_path(lesson.course, lesson), class: "btn btn-sm btn-outline-warning d-flex align-items-center justify-content-center px-2 py-1.5 rounded-2" do %>
          <i class="fa-solid fa-pen-to-square" style="font-size: 0.8rem;"></i>
        <% end %>
      <% end %>
      <% if current_user && defined?(LessonPolicy) && policy(lesson).destroy? %>
        <%= button_to [lesson.course, lesson], method: :delete, data: { turbo_confirm: "Are you sure you want to delete this lesson?" }, class: "btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center px-2 py-1.5 rounded-2" do %>
          <i class="fa-solid fa-trash" style="font-size: 0.8rem;"></i>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
