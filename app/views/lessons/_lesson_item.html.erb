<div class="card border border-light-subtle rounded-3 p-3 mb-3 shadow-none hover-shadow-sm transition-all" id="<%= dom_id lesson %>">
  <div class="d-flex justify-content-between align-items-start gap-3">
    <div class="text-truncate flex-grow-1">
      <h5 class="fw-bold fs-6 mb-1 text-truncate">
        <%= link_to lesson.title, lesson, class: "text-decoration-none text-dark hover-text-primary" %>
      </h5>
      <div class="text-secondary small text-truncate" style="max-height: 40px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;">
        <% if current_user && defined?(LessonPolicy) && policy(lesson).show? %>
          <%= strip_tags(lesson.content.to_plain_text).truncate(80) %>
        <% else %>
          <span class="text-muted"><i class="fa-solid fa-lock me-1 small"></i> Content is locked</span>
        <% end %>
      </div>
    </div>
    
    <div class="d-flex gap-1 flex-shrink-0">
      <% if current_user && defined?(LessonPolicy) && policy(lesson).show? %>
        <%= link_to lesson, class: "btn btn-sm btn-outline-secondary d-flex align-items-center justify-content-center px-2 py-1.5 rounded-2" do %>
          <i class="fa-solid fa-eye" style="font-size: 0.8rem;"></i>
        <% end %>
      <% end %>
      <% if current_user && defined?(LessonPolicy) && policy(lesson).edit? %>
        <%= link_to edit_lesson_path(lesson), class: "btn btn-sm btn-outline-warning d-flex align-items-center justify-content-center px-2 py-1.5 rounded-2" do %>
          <i class="fa-solid fa-pen-to-square" style="font-size: 0.8rem;"></i>
        <% end %>
      <% end %>
      <% if current_user && defined?(LessonPolicy) && policy(lesson).destroy? %>
        <%= button_to lesson, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this lesson?" }, class: "btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center px-2 py-1.5 rounded-2" do %>
          <i class="fa-solid fa-trash" style="font-size: 0.8rem;"></i>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
