<% content_for :title, "Course: #{@course.title} | Lesson: #{@lesson.title}" %>

<div class="container py-5">
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-transparent p-0 m-0">
      <li class="breadcrumb-item">
        <%= link_to courses_path, class: "text-decoration-none text-secondary fw-semibold" do %>
          <i class="fa-solid fa-book-open me-1"></i> Courses
        <% end %>
      </li>
      <li class="breadcrumb-item">
        <%= link_to @course.title, @course, class: "text-decoration-none text-secondary fw-semibold" %>
      </li>
      <li class="breadcrumb-item active text-dark fw-bold" aria-current="page"><%= @lesson.title %></li>
    </ol>
  </nav>

  <div class="row g-4 align-items-start">
    <main class="col-lg-8">
      <article class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
        <header class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4 pb-4 border-bottom">
          <span class="badge px-3 py-2 fw-semibold lesson-label">
            <i class="fa-solid fa-book-bookmark me-1"></i> Lesson
          </span>
          <span class="text-muted small">
            <i class="fa-regular fa-clock me-1"></i> Updated <%= @lesson.updated_at.strftime("%b %d, %Y") %>
          </span>
        </header>

        <h1 class="display-6 fw-bold text-dark mb-4 font-heading"><%= @lesson.title %></h1>

        <div class="trix-content text-secondary fs-5 lesson-reading-content">
          <%= @lesson.content %>
        </div>

        <% if current_user && (policy(@lesson).edit? || policy(@lesson).destroy?) %>
          <footer class="border-top pt-4 mt-5 d-flex justify-content-end gap-2">
            <% if policy(@lesson).edit? %>
              <%= link_to edit_course_lesson_path(@course, @lesson), class: "btn btn-outline-primary fw-bold px-4 py-2 rounded-pill" do %>
                <i class="fa-solid fa-pen-to-square me-1"></i> Edit
              <% end %>
            <% end %>
            <% if policy(@lesson).destroy? %>
              <%= button_to [@course, @lesson], method: :delete, data: { turbo_confirm: "Are you sure you want to delete this lesson?" }, class: "btn btn-outline-danger fw-bold px-4 py-2 rounded-pill" do %>
                <i class="fa-solid fa-trash me-1"></i> Delete
              <% end %>
            <% end %>
          </footer>
        <% end %>
      </article>
    </main>

    <aside class="col-lg-4" aria-label="Course curriculum">
      <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden lesson-curriculum-sticky" data-lesson-curriculum>
        <div class="p-4 border-bottom">
          <span class="text-uppercase text-secondary fw-bold lesson-curriculum__eyebrow">Course curriculum</span>
          <%= link_to @course, class: "d-flex align-items-start justify-content-between gap-3 mt-2 text-decoration-none text-dark" do %>
            <span class="fw-bold font-heading"><%= @course.title %></span>
            <i class="fa-solid fa-arrow-up-right-from-square small mt-1 text-secondary" aria-hidden="true"></i>
          <% end %>

          <div class="mt-3">
            <%= render "courses/progress", course: @course %>
          </div>
        </div>

        <nav class="lesson-curriculum__list" aria-label="Lessons in <%= @course.title %>">
          <% (@lessons || []).each_with_index do |lesson, index| %>
            <%= render "lessons/curriculum_item", lesson: lesson, current_lesson: @lesson, index: index %>
          <% end %>
        </nav>

        <% if (@lessons || []).empty? %>
          <div class="p-4 text-center text-secondary small" data-empty-curriculum>
            Curriculum is not available yet.
          </div>
        <% end %>
      </div>
    </aside>
  </div>
</div>
