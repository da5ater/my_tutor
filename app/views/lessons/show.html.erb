<% content_for :title, "Course: #{@course.title} | Lesson: #{@lesson.title}" %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <!-- Breadcrumbs -->
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0 m-0">
          <li class="breadcrumb-item">
            <%= link_to courses_path, class: "text-decoration-none text-secondary fw-semibold" do %>
              <i class="fa-solid fa-book-open me-1"></i> Courses
            <% end %>
          </li>
          <li class="breadcrumb-item">
            <%= link_to @lesson.course, class: "text-decoration-none text-secondary fw-semibold" do %>
              <%= @lesson.course.title %>
            <% end %>
          </li>
          <li class="breadcrumb-item active text-dark fw-extrabold" aria-current="page">
            <%= @lesson.title %>
          </li>
        </ol>
      </nav>

      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
        <div class="d-flex align-items-center justify-content-between mb-4">
          <span class="badge mb-0 px-3 py-2 fw-semibold" style="background-color: rgba(255, 56, 92, 0.1); color: #ff385c; border-radius: 50px;">
            <i class="fa-solid fa-book-bookmark me-1"></i> Lesson
          </span>
          <span class="text-muted small">
            <i class="fa-regular fa-clock me-1"></i> Updated <%= @lesson.updated_at.strftime('%b %d, %Y') %>
          </span>
        </div>

        <h1 class="display-6 fw-extrabold text-dark mb-4 font-heading"><%= @lesson.title %></h1>

        <div class="trix-content text-secondary mb-5 fs-5" style="line-height: 1.6;">
          <%= @lesson.content %>
        </div>

        <div class="border-top pt-4 d-flex justify-content-between align-items-center">
          <div>
            <%= link_to @lesson.course, class: "btn btn-link px-0 text-decoration-none text-secondary fw-semibold d-inline-flex align-items-center gap-2" do %>
              <i class="fa-solid fa-arrow-left"></i> Back to Course
            <% end %>
          </div>
          <div class="d-flex gap-2">
            <% if current_user && defined?(LessonPolicy) && policy(@lesson).edit? %>
              <%= link_to edit_course_lesson_path(@course, @lesson), class: "btn btn-outline-warning fw-bold px-4 py-2.5 rounded-pill" do %>
                <i class="fa-solid fa-pen-to-square me-1"></i> Edit
              <% end %>
            <% end %>
            <% if current_user && defined?(LessonPolicy) && policy(@lesson).destroy? %>
              <%= button_to [@course, @lesson], method: :delete, data: { turbo_confirm: "Are you sure you want to delete this lesson?" }, class: "btn btn-danger fw-bold px-4 py-2.5 rounded-pill" do %>
                <i class="fa-solid fa-trash me-1"></i> Delete
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
