<div class="container py-5" style="max-width: 720px;">
  <div class="mb-4">
    <%= link_to [@course, @lesson], class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
      <i class="fa-solid fa-arrow-left"></i> Cancel and View Lesson
    <% end %>
  </div>

  <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
    <span class="badge align-self-start mb-3 px-3 py-2 fw-semibold" style="background-color: rgba(255, 56, 92, 0.1); color: #ff385c; border-radius: 50px;">
      <i class="fa-solid fa-pen-to-square me-1"></i> Edit Lesson
    </span>
    <h1 class="h2 fw-extrabold text-dark mb-4 font-heading">Edit Lesson</h1>
    <%= render "form", lesson: @lesson %>
  </div>
</div>
