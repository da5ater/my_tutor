<div class="container py-5" style="max-width: 680px;">
  <div class="mb-4">
    <%= link_to users_path, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
      <i class="fa-solid fa-arrow-left"></i> Back to Users Directory
    <% end %>
  </div>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
    <!-- Top accent bar -->
    <div style="height: 6px; background-color: #ff385c;"></div>

    <div class="card-header bg-white border-bottom p-4">
      <h4 class="fw-bold text-dark font-heading mb-1">Editing Roles for <%= @user.email %></h4>
      <p class="text-secondary mb-0 small">Select the roles to assign to this user account.</p>
    </div>

    <%= form_with(model: @user, local: true, class: "needs-validation") do |f| %>
      <div class="card-body p-4">
        <% if @user.errors.any? %>
          <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-4" role="alert">
            <h6 class="fw-bold mb-2"><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h6>
            <ul class="mb-0 ps-3 small">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <label class="form-label fw-bold text-dark mb-3">Roles Configuration</label>
          
          <div class="d-flex flex-column gap-3">
            <%= f.collection_check_boxes :role_ids, Role.all, :id, :name do |b| %>
              <div class="p-3 border rounded-3 d-flex align-items-start gap-3 bg-light bg-opacity-25 hover-border-primary transition-all">
                <div class="d-flex align-items-center h-100 pt-1">
                  <%= b.check_box class: "form-check-input flex-shrink-0 cursor-pointer", style: "width: 20px; height: 20px; accent-color: #ff385c;" %>
                </div>
                <div class="cursor-pointer flex-grow-1" onclick="this.previousElementSibling.firstElementChild.click()">
                  <div class="fw-bold text-dark mb-1 d-flex align-items-center gap-2">
                    <%= b.text.titleize %>
                    <% case b.text %>
                    <% when 'admin' %>
                      <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill fw-semibold px-2 py-0.5" style="font-size: 0.65rem;">System Owner</span>
                    <% when 'teacher' %>
                      <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill fw-semibold px-2 py-0.5" style="font-size: 0.65rem;">Course Author</span>
                    <% when 'student' %>
                      <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill fw-semibold px-2 py-0.5" style="font-size: 0.65rem;">Learner</span>
                    <% end %>
                  </div>
                  <div class="text-secondary small">
                    <% case b.text %>
                    <% when 'admin' %>
                      Full permissions to manage users, courses, analytics, and platform settings.
                    <% when 'teacher' %>
                      Permissions to create, update, and manage their own tutoring programs.
                    <% when 'student' %>
                      Default role for browsing, enrolling, and participating in tutoring programs.
                    <% else %>
                      Custom user role permission group.
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="card-footer bg-light border-top p-4 d-flex align-items-center justify-content-end gap-3">
        <%= link_to "Cancel", users_path, class: "btn btn-link text-decoration-none text-secondary fw-semibold px-3 py-2" %>
        <%= f.submit "Update User Roles", class: "btn btn-primary px-4 py-2.5 fw-bold shadow-sm rounded-pill", style: "background-color: #ff385c; border-color: #ff385c;" %>
      </div>
    <% end %>
  </div>
</div>

<style>
  .hover-border-primary:hover {
    border-color: #ff385c !important;
  }
  .transition-all {
    transition: all 0.2s ease-in-out;
  }
  .cursor-pointer {
    cursor: pointer;
  }
</style>
