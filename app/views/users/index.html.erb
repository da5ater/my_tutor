<div class="container py-5">
  <% content_for :title, "Users Directory" %>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-5 animate-fade-in">
    <div>
      <h1 class="display-6 fw-extrabold text-dark mb-1 font-heading">Users</h1>
      <p class="text-muted mb-0">Browse registered tutors and student accounts.</p>
    </div>
  </div>

  <% if @users.any? %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% @users.each do |user| %>
        <div class="col">
          <%= render user %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
      <div class="py-4">
        <i class="fa-solid fa-users fa-3x mb-3 text-secondary opacity-50"></i>
        <h4 class="fw-bold text-dark font-heading">No users registered</h4>
        <p class="text-muted mb-0">Wait, how did you get here? There should be at least your own account!</p>
      </div>
    </div>
  <% end %>

  <div class="mt-5">
    <%= link_to root_path, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
      <i class="fa-solid fa-arrow-left"></i> Back to Home
    <% end %>
  </div>
</div>
