<div class="container py-5">
  <% content_for :title, "All Users" %>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4 animate-fade-in">
    <div>
      <h3 class="fw-bold text-dark mb-1 font-heading">
        Users
        <span class="badge bg-info text-white"><%= @users.count %></span>
      </h3>
      <p class="text-secondary mb-0">Browse, search, and sort registered tutors and student accounts.</p>
    </div>
  </div>

  <div class="card-premium p-3 p-md-4 mb-4">
    <%= search_form_for @q, url: users_path, method: :get, html: { class: "row g-3 align-items-end" } do |f| %>
      <div class="col-12 col-md-5">
        <%= f.label :email_cont, "Email", class: "form-label fw-semibold small text-secondary" %>
        <%= f.search_field :email_cont, placeholder: "Search by email", class: "form-control rounded-pill px-4" %>
      </div>

      <div class="col-12 col-md-4">
        <%= f.label :sign_in_count_eq, "Sign in count", class: "form-label fw-semibold small text-secondary" %>
        <%= f.search_field :sign_in_count_eq, placeholder: "Exact count", class: "form-control rounded-pill px-4" %>
      </div>

      <div class="col-12 col-md-3 d-flex gap-2">
        <%= f.button class: "btn btn-primary rounded-pill flex-fill d-inline-flex align-items-center justify-content-center gap-2" do %>
          <i class="fa-solid fa-magnifying-glass"></i>
          <span>Search</span>
        <% end %>

        <%= link_to users_path, class: "btn btn-outline-secondary rounded-pill d-inline-flex align-items-center justify-content-center", title: "Clear search" do %>
          <i class="fa-solid fa-rotate-left"></i>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="card-premium overflow-hidden">
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="px-4 py-3">
              <%= sort_link(@q, :email, "Email", {}, { class: "text-decoration-none text-secondary fw-bold d-inline-flex align-items-center gap-2" }) %>
            </th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">
              <%= sort_link(@q, :sign_in_count, "Sign ins", {}, { class: "text-decoration-none text-secondary fw-bold d-inline-flex align-items-center gap-2" }) %>
            </th>
            <th class="px-4 py-3">Last signed in</th>
            <th class="px-4 py-3">
              <%= sort_link(@q, :created_at, "Joined", {}, { class: "text-decoration-none text-secondary fw-bold d-inline-flex align-items-center gap-2" }) %>
            </th>
            <th class="px-4 py-3 text-end" style="width: 15%;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if @users.any? %>
            <% @users.each do |user| %>
              <tr>
                <td class="px-4 py-3">
                  <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border" style="width: 42px; height: 42px; flex-shrink: 0;">
                      <i class="fa-solid fa-circle-user text-secondary fs-4"></i>
                    </div>
                    <div class="text-truncate">
                      <div class="fw-bold text-dark text-truncate d-flex align-items-center gap-2" title="<%= user.email %>">
                        <% if user.respond_to?(:online?) && user.online? %>
                          <i class="fa-solid fa-circle text-success" style="font-size: 0.6rem;" title="Online"></i>
                        <% else %>
                          <i class="fa-solid fa-circle text-danger" style="font-size: 0.6rem;" title="Offline"></i>
                        <% end %>
                        <%= link_to user.email, user, class: "text-decoration-none text-dark hover-underline" %>
                      </div>
                      <div class="d-flex flex-wrap gap-1 mt-1">
                        <% if user.roles.any? %>
                          <% user.roles.each do |role| %>
                            <span class="badge bg-info text-white rounded-pill px-2 py-0.5" style="font-size: 0.7rem;"><%= role.name.titleize %></span>
                          <% end %>
                        <% else %>
                          <span class="text-muted small" style="font-size: 0.7rem;">No roles</span>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <% if user.confirmed_at.present? %>
                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-2">
                      <i class="fa-solid fa-circle-check me-1"></i> Confirmed
                    </span>
                  <% else %>
                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle rounded-pill px-3 py-2">
                      <i class="fa-solid fa-circle-exclamation me-1"></i> Pending
                    </span>
                  <% end %>
                </td>
                <td class="px-4 py-3">
                  <span class="badge bg-light text-dark border rounded-pill px-3 py-2"><%= user.sign_in_count || 0 %></span>
                </td>
                <td class="px-4 py-3 text-secondary">
                  <% if user.last_sign_in_at.present? %>
                    <%= time_ago_in_words(user.last_sign_in_at) %> ago
                  <% else %>
                    <span class="text-muted">Never</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-secondary"><%= time_ago_in_words(user.created_at) %> ago</td>
                <td class="px-4 py-3 text-end">
                  <% if policy(user).edit? %>
                    <%= link_to edit_user_path(user), class: "btn btn-sm btn-outline-primary rounded-2 px-3 py-1.5 fw-semibold d-inline-flex align-items-center gap-1" do %>
                      <i class="fa-solid fa-user-gear"></i> Edit Roles
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5" class="px-4 py-5 text-center">
                <i class="fa-solid fa-users fa-3x mb-3 text-secondary opacity-50"></i>
                <h4 class="fw-bold text-dark font-heading">No users found</h4>
                <p class="text-muted mb-0">Try a different email or sign-in count.</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-5">
    <%= link_to root_path, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
      <i class="fa-solid fa-arrow-left"></i> Back to Home
    <% end %>
  </div>
</div>
