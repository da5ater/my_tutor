<div class="container py-5">
  <% content_for :title, "Courses" %>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-5">
    <div>
      <h1 class="display-6 fw-extrabold text-dark mb-1 font-heading">
        <% if params[:title].present? %>
          Search Results
        <% else %>
          Courses
        <% end %>
      </h1>
      <p class="text-muted mb-0">
        <% if params[:title].present? %>
          Found <%= @courses.count %> <%= "course".pluralize(@courses.count) %> matching "<%= params[:title] %>"
        <% else %>
          Browse and manage available tutoring programs.
        <% end %>
      </p>
    </div>
    
    <div class="d-flex align-items-center gap-3">
      <!-- Search Form -->
      <%= form_with(url: courses_path, method: :get, local: true, class: "d-flex align-items-center gap-2 bg-light p-1 rounded-pill border") do |f| %>
        <%= f.text_field :title, value: params[:title], placeholder: "Search courses...", class: "form-control border-0 bg-transparent py-1.5 px-3 small", style: "box-shadow: none; font-size: 0.9rem;" %>
        <%= f.button type: :submit, class: "btn btn-primary rounded-circle p-2 d-flex align-items-center justify-content-center", style: "width: 34px; height: 34px;" do %>
          <i class="fa-solid fa-magnifying-glass small"></i>
        <% end %>
      <% end %>
      
      <%= link_to new_course_path, class: "btn btn-primary px-4 py-2.5 rounded-pill fw-bold shadow-sm d-none d-sm-flex align-items-center gap-2" do %>
        <i class="fa-solid fa-plus"></i> Add Course
      <% end %>
    </div>
  </div>

  <% if @courses.any? %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% @courses.each do |course| %>
        <div class="col">
          <%= render course %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
      <div class="py-4">
        <i class="fa-solid fa-folder-open fa-3x mb-3 text-secondary opacity-50"></i>
        <h4 class="fw-bold text-dark font-heading">No courses found</h4>
        <p class="text-muted mb-4">We couldn't find any courses matching your search criteria.</p>
        <div class="d-flex justify-content-center gap-2">
          <%= link_to "Clear Search", courses_path, class: "btn btn-outline-secondary px-4 py-2 fw-bold rounded-pill" if params[:title].present? %>
          <%= link_to "Add a Course", new_course_path, class: "btn btn-primary px-4 py-2 fw-bold rounded-pill" %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="mt-5">
    <%= link_to root_path, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
      <i class="fa-solid fa-arrow-left"></i> Back to Home
    <% end %>
  </div>
</div>
