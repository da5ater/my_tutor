<div class="container py-5">
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 d-flex align-items-center" role="alert">
      <i class="fa-solid fa-circle-check me-2"></i>
      <div><%= notice %></div>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <% current_action_title = action_name == 'index' ? 'All' : action_name.humanize %>
  <% content_for :title, "#{current_action_title} Courses" %>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h3 class="fw-bold text-dark mb-1 font-heading">
        <%= current_action_title %> Courses
        <span class="badge bg-info text-white"><%= @courses.count %></span>
      </h3>
      <p class="text-secondary mb-0">Browse and manage available tutoring programs.</p>
    </div>
    <div>
      <%= link_to new_course_path, class: "btn btn-primary px-4 py-2.5 rounded-3 fw-bold shadow-sm d-flex align-items-center gap-2" do %>
        <i class="fa-solid fa-plus"></i> New Course
      <% end %>
    </div>
  </div>

  <div class="row g-4">
    <aside class="col-12 col-lg-3">
      <div class="card-premium p-3 p-md-4">
        <%= search_form_for @ransack_courses, as: :courses_search, url: (@ransack_path || courses_path), method: :get, html: { class: "d-flex flex-column gap-3" } do |f| %>
          <div>
            <%= f.label :title_cont, "Title", class: "form-label fw-semibold small text-secondary" %>
            <%= f.search_field :title_cont, placeholder: "Course title", class: "form-control rounded-pill px-4" %>
          </div>

          <div>
            <%= f.label :short_description_cont, "Description", class: "form-label fw-semibold small text-secondary" %>
            <%= f.search_field :short_description_cont, placeholder: "Short description", class: "form-control rounded-pill px-4" %>
          </div>

          <div>
            <%= f.label :language_cont, "Language", class: "form-label fw-semibold small text-secondary" %>
            <%= select_tag "courses_search[language_cont]", options_for_select([["Any language", ""]] + Course.languages, params.dig(:courses_search, :language_cont)), class: "form-select rounded-pill px-4" %>
          </div>

          <div>
            <%= f.label :level_cont, "Level", class: "form-label fw-semibold small text-secondary" %>
            <%= select_tag "courses_search[level_cont]", options_for_select([["Any level", ""]] + Course.levels, params.dig(:courses_search, :level_cont)), class: "form-select rounded-pill px-4" %>
          </div>

          <div>
            <%= f.label :price_eq, "Price", class: "form-label fw-semibold small text-secondary" %>
            <%= f.search_field :price_eq, placeholder: "Exact price", class: "form-control rounded-pill px-4" %>
          </div>

          <div>
            <%= f.label :user_email_cont, "Teacher", class: "form-label fw-semibold small text-secondary" %>
            <%= f.search_field :user_email_cont, placeholder: "Teacher email", class: "form-control rounded-pill px-4" %>
          </div>

          <div class="border-top pt-3">
            <span class="fw-semibold small text-secondary d-block mb-2">Sort by</span>
            <div class="d-flex flex-column gap-2">
              <div>
                <%= sort_link(@ransack_courses, :price, "Price", class: "text-decoration-none text-secondary small fw-semibold hover-underline") %>
              </div>
              <div>
                <%= sort_link(@ransack_courses, :average_rating, "Top Rated", class: "text-decoration-none text-secondary small fw-semibold hover-underline") %>
              </div>
              <div>
                <%= sort_link(@ransack_courses, :enrollments_count, "Most Popular", class: "text-decoration-none text-secondary small fw-semibold hover-underline") %>
              </div>
              <div>
                <%= sort_link(@ransack_courses, :created_at, "Latest Created", class: "text-decoration-none text-secondary small fw-semibold hover-underline") %>
              </div>
            </div>
          </div>

          <div class="d-flex gap-2 pt-2">
            <%= f.button class: "btn btn-primary rounded-pill flex-fill d-inline-flex align-items-center justify-content-center gap-2" do %>
              <i class="fa-solid fa-magnifying-glass"></i>
              <span>Search</span>
            <% end %>

            <%= link_to (@ransack_path || courses_path), class: "btn btn-outline-secondary rounded-pill d-inline-flex align-items-center justify-content-center", title: "Clear search" do %>
              <i class="fa-solid fa-rotate-left"></i>
            <% end %>
          </div>
        <% end %>
      </div>
    </aside>

    <div class="col-12 col-lg-9">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light border-bottom">
              <tr>
                <th scope="col" class="py-3 px-4 text-secondary font-heading fw-bold" style="width: 24%;">
                  <%= sort_link(@ransack_courses, :title, "Course Title", class: "text-decoration-none text-secondary fw-bold") %>
                </th>
                <th scope="col" class="py-3 px-4 text-secondary font-heading fw-bold">Details</th>
                <th scope="col" class="py-3 px-4 text-secondary font-heading fw-bold">Rating</th>
                <th scope="col" class="py-3 px-4 text-secondary font-heading fw-bold">Teacher</th>
                <th scope="col" class="py-3 px-4 text-secondary font-heading fw-bold text-end" style="width: 22%;">Actions</th>
              </tr>
            </thead>
            <tbody class="border-top-0">
              <% if @courses.any? %>
                <% @courses.each do |course| %>
                  <tr id="<%= dom_id course %>">
                    <td class="py-3 px-4">
                      <div class="fw-semibold text-dark"><%= course.title %></div>
                      <div class="text-muted small"><%= course.short_description %></div>
                    </td>
                    <td class="py-3 px-4">
                      <div class="d-flex flex-wrap gap-2">
                        <span class="badge bg-light text-dark border rounded-pill px-3 py-2"><%= course.language %></span>
                        <span class="badge bg-light text-dark border rounded-pill px-3 py-2"><%= course.level %></span>
                        <span class="badge bg-light text-dark border rounded-pill px-3 py-2"><%= number_to_currency(course.price, precision: 0) %></span>
                        <span class="badge bg-light text-secondary border rounded-pill px-3 py-2" title="Enrolled Students">
                          <i class="fa-solid fa-user-group me-1" style="color: #ff385c;"></i> <%= course.respond_to?(:enrollments_count) ? course.enrollments_count : course.enrollments.count %>
                        </span>
                      </div>
                    </td>
                    <td class="py-3 px-4">
                      <% 
                        rated_enrollments = course.enrollments.where.not(rating: nil)
                        avg_rating = (course.respond_to?(:average_rating) && course.average_rating.present? && course.average_rating > 0) ? course.average_rating : (rated_enrollments.any? ? rated_enrollments.average(:rating).round(1).to_f : 0.0)
                      %>
                      <% if avg_rating > 0 %>
                        <span class="badge text-dark bg-light border fw-bold small px-2 py-1" title="Average Rating">
                          <i class="fa-solid fa-star" style="color: var(--ink-color);"></i> <%= avg_rating %>
                        </span>
                      <% else %>
                        <span class="text-muted small italic">No ratings</span>
                      <% end %>
                    </td>
                    <td class="py-3 px-4 text-secondary small"><%= course.user&.username || "Unknown Tutor" %></td>
                    <td class="py-3 px-4 text-end">
                      <div class="d-inline-flex gap-2">
                        <%= link_to course, class: "btn btn-sm btn-outline-secondary d-flex align-items-center gap-1 px-3 py-1.5 rounded-2" do %>
                          <i class="fa-solid fa-eye small"></i> Show
                        <% end %>
                        <% if current_user && policy(course).edit? %>
                          <%= link_to edit_course_path(course), class: "btn btn-sm btn-outline-primary d-flex align-items-center gap-1 px-3 py-1.5 rounded-2" do %>
                            <i class="fa-solid fa-pen-to-square small"></i> Edit
                          <% end %>
                        <% end %>
                        <% if current_user && policy(course).destroy? %>
                          <%= button_to course, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this course?" }, class: "btn btn-sm btn-outline-danger d-flex align-items-center gap-1 px-3 py-1.5 rounded-2" do %>
                            <i class="fa-solid fa-trash small"></i> Delete
                          <% end %>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="5" class="text-center py-5 text-muted">
                    <i class="fa-solid fa-folder-open fa-2x mb-3 d-block opacity-50"></i>
                    No courses found. Try a different search.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
      <% if @pagy.present? && @pagy.pages > 1 %>
        <div class="mt-4 d-flex justify-content-center">
          <%== @pagy.series_nav(:bootstrap) %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-4">
    <%= link_to root_path, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
      <i class="fa-solid fa-arrow-left"></i> Back to Home
    <% end %>
  </div>
</div>
