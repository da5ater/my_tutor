<% content_for :title, "Editing #{@course.title}" %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
        <h1 class="display-6 fw-extrabold text-dark mb-4 font-heading">Edit Course</h1>

        <%= render "form", course: @course %>

        <div class="mt-4 pt-3 border-top d-flex gap-3">
          <%= link_to @course, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-primary" do %>
            <i class="fa-solid fa-eye"></i> Show Course
          <% end %>
          <span class="text-muted d-flex align-items-center">|</span>
          <%= link_to courses_path, class: "btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2 fw-semibold text-secondary" do %>
            <i class="fa-solid fa-arrow-left"></i> Back to Courses
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

