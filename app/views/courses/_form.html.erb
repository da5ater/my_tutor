<%= simple_form_for(@course, html: { class: "needs-validation" }) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs mb-4">
    <%= f.input :title, 
                required: true, 
                placeholder: "e.g. Introduction to Rails 8", 
                input_html: { class: "form-control py-2.5" } %>
                
    <%= f.input :description, 
                as: :rich_text_area,
                required: true, 
                placeholder: "Provide a detailed description of the course (minimum 50 characters)...", 
                input_html: { class: "form-control py-2.5", rows: 6 } %>

    <%= f.input :short_description,
                required: true,
                placeholder: "A short summary for course cards and search results",
                input_html: { class: "form-control py-2.5" } %>

    <div class="row g-3">
      <div class="col-12 col-md-4">
        <%= f.input :language,
                    collection: Course.languages,
                    include_blank: "Choose language",
                    required: true,
                    input_html: { class: "form-select py-2.5" } %>
      </div>

      <div class="col-12 col-md-4">
        <%= f.input :level,
                    collection: Course.levels,
                    include_blank: "Choose level",
                    required: true,
                    input_html: { class: "form-select py-2.5" } %>
      </div>

      <div class="col-12 col-md-4">
        <%= f.input :price,
                    required: true,
                    placeholder: "0",
                    input_html: { class: "form-control py-2.5", min: 0, step: 1 } %>
      </div>
    </div>
  </div>

  <div class="form-actions">
    <%= f.button :submit, class: "btn btn-primary btn-lg py-2.5 w-100 fw-bold shadow-sm rounded-3" %>
  </div>
<% end %>
