<% content_for :title, @course.title %>
<div class="container py-5">
  <!-- Breadcrumbs -->
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-transparent p-0 m-0">
      <li class="breadcrumb-item">
        <%= link_to courses_path, class: "text-decoration-none text-secondary fw-semibold" do %>
          <i class="fa-solid fa-book-open me-1"></i> Courses
        <% end %>
      </li>
      <li class="breadcrumb-item active text-dark fw-extrabold" aria-current="page">
        <%= @course.title %>
      </li>
    </ol>
  </nav>

  <div class="row g-4">
    <!-- Left Column: Course Details -->
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white h-100 d-flex flex-column">
        <div class="d-flex align-items-center justify-content-between mb-4">
          <span class="badge mb-0 px-3 py-2 fw-semibold" style="background-color: rgba(255, 56, 92, 0.1); color: #ff385c; border-radius: 50px;">
            <i class="fa-solid fa-graduation-cap me-1"></i> Course Details
          </span>
          <span class="text-muted small">
            <i class="fa-regular fa-clock me-1"></i> Created <%= @course.created_at.strftime('%b %d, %Y') %>
          </span>
        </div>
        
        <h1 class="display-6 fw-extrabold text-dark mb-3 font-heading"><%= @course.title %></h1>
        
        <div class="d-flex flex-wrap align-items-center gap-2 mb-4 pb-3 border-bottom">
          <span class="badge bg-light text-secondary border px-3 py-2 fw-normal">
            <i class="fa-solid fa-chalkboard-user me-1"></i> Tutor: 
            <% if @course.user %>
              <%= link_to @course.user.username, user_path(@course.user), class: "text-decoration-none text-secondary hover-underline fw-semibold ms-1" %>
            <% else %>
              Unknown Tutor
            <% end %>
          </span>
          <% 
            rated_enrollments = @course.enrollments.where.not(rating: nil)
            avg_rating = (@course.respond_to?(:average_rating) && @course.average_rating.present? && @course.average_rating > 0) ? @course.average_rating : (rated_enrollments.any? ? rated_enrollments.average(:rating).round(1).to_f : 0.0)
            students_count = @course.respond_to?(:enrollments_count) ? @course.enrollments_count : @course.enrollments.count
          %>
          <% if avg_rating > 0 %>
            <span class="badge bg-light text-dark border px-3 py-2 fw-bold" title="Average Rating">
              <i class="fa-solid fa-star" style="color: var(--ink-color);"></i> <%= avg_rating %>
            </span>
          <% end %>
          <span class="badge bg-light text-secondary border px-3 py-2 fw-bold" title="Enrolled Students">
            <i class="fa-solid fa-user-group me-1" style="color: #ff385c;"></i> <%= pluralize(students_count, 'student') %>
          </span>
          <%= enrollment_button(@course) %>
          <%= review_button(@course) %>
        </div>
        
        <div class="trix-content text-secondary mb-5 fs-5 flex-grow-1" style="line-height: 1.6;">
          <%= @course.description %>
        </div>

        <div class="border-top pt-4 mt-auto d-flex justify-content-between align-items-center">
          <div>
            <%= link_to courses_path, class: "btn btn-link px-0 text-decoration-none text-secondary fw-semibold d-inline-flex align-items-center gap-2" do %>
              <i class="fa-solid fa-arrow-left"></i> Back to Courses
            <% end %>
          </div>
          <div class="d-flex gap-2">
            <% if current_user && policy(@course).edit? %>
              <%= link_to edit_course_path(@course), class: "btn btn-outline-primary fw-bold px-4 py-2.5 rounded-pill" do %>
                <i class="fa-solid fa-pen-to-square me-1"></i> Edit
              <% end %>
            <% end %>
            <% if current_user && policy(@course).destroy? %>
              <%= button_to @course, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this course?" }, class: "btn btn-danger fw-bold px-4 py-2.5 rounded-pill" do %>
                <i class="fa-solid fa-trash me-1"></i> Delete
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column: Lessons list -->
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white h-100 d-flex flex-column">
        <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
          <h3 class="fw-extrabold text-dark font-heading m-0 d-flex align-items-center gap-2">
            <i class="fa-solid fa-book-bookmark text-primary"></i> Lessons
            <span class="badge bg-light text-secondary border rounded-pill fs-6 px-2.5 py-1">
              <%= @course.respond_to?(:lessons_count) ? @course.lessons_count : @course.lessons.count %>
            </span>
          </h3>
          <% if current_user && policy(@course).respond_to?(:owner?) && policy(@course).owner? %>
            <%= link_to new_course_lesson_path(@course), class: "btn btn-primary btn-sm rounded-pill px-3 py-2 fw-bold d-flex align-items-center gap-1" do %>
              <i class="fa-solid fa-plus small"></i> Add Lesson
            <% end %>
          <% end %>
        </div>

        <div class="lessons-container d-flex flex-column gap-1 overflow-auto flex-grow-1" style="max-height: 500px;">
          <% if @lessons.present? %>
            <% @lessons.each do |lesson| %>
              <%= render 'lessons/lesson_item', lesson: lesson %>
            <% end %>
          <% else %>
            <div class="text-center py-5 text-muted my-auto">
              <i class="fa-solid fa-book-open fs-1 mb-3 text-secondary opacity-50"></i>
              <p class="m-0 fw-semibold">No lessons available for this course yet.</p>
              <% if current_user && policy(@course).respond_to?(:owner?) && policy(@course).owner? %>
                <small class="text-secondary d-block mt-1">Click the "Add Lesson" button above to create one.</small>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Reviews Section -->
  <div class="row g-4 mt-2">
    <div class="col-12">
      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
        <h3 class="fw-extrabold text-dark font-heading mb-4 d-flex align-items-center gap-2">
          <i class="fa-solid fa-star text-primary" style="color: var(--ink-color) !important;"></i> Reviews
          <span class="badge bg-light text-secondary border rounded-pill fs-6 px-2.5 py-1">
            <%= @course.enrollments.where.not(rating: nil).count %>
          </span>
        </h3>
        
        <% reviews = @course.enrollments.where.not(rating: nil).order(updated_at: :desc) %>
        <% if reviews.any? %>
          <!-- Airbnb-style Rating Display Card & distribution -->
          <div class="row g-4 mb-5 pb-4 border-bottom align-items-center">
            <!-- Left Side: Large Rating Summary -->
            <div class="col-md-4 d-flex flex-column align-items-center align-items-md-start border-end border-light-subtle pr-md-4">
              <div class="d-flex align-items-center gap-3">
                <span class="fw-extrabold font-heading text-dark m-0" style="font-size: 3.5rem; line-height: 1;"><%= avg_rating %></span>
                <div>
                  <div class="d-flex text-dark fs-5">
                    <% avg_rating.round.times do %>
                      <i class="fa-solid fa-star text-dark"></i>
                    <% end %>
                    <% (5 - avg_rating.round).times do %>
                      <i class="fa-regular fa-star text-secondary"></i>
                    <% end %>
                  </div>
                  <div class="text-secondary small fw-semibold mt-1">
                    <%= pluralize(reviews.count, 'student review') %>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Right Side: Star Breakdown Bars -->
            <div class="col-md-8 pl-md-4">
              <div class="d-flex flex-column gap-2 ms-md-4" style="max-width: 450px;">
                <% (1..5).to_a.reverse.each do |stars| %>
                  <% 
                    count_stars = reviews.where(rating: stars).count
                    pct = reviews.count > 0 ? (count_stars.to_f / reviews.count * 100).round : 0
                  %>
                  <div class="d-flex align-items-center gap-3">
                    <span class="text-secondary small fw-semibold" style="width: 50px;"><%= stars %> <%= 'star'.pluralize(stars) %></span>
                    <div class="progress flex-grow-1" style="height: 6px; background-color: var(--surface-soft); border-radius: 3px;">
                      <div class="progress-bar bg-dark" role="progressbar" style="width: <%= pct %>%; border-radius: 3px;" aria-valuenow="<%= pct %>" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <span class="text-muted small" style="width: 35px; text-align: right;"><%= pct %>%</span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>

          <div class="row row-cols-1 row-cols-md-2 g-4">
            <% reviews.each do |enrollment| %>
              <div class="col">
                <%= render 'enrollments/enrollment', enrollment: enrollment %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-5 text-muted">
            <i class="fa-regular fa-star fs-1 mb-3 text-secondary opacity-50"></i>
            <p class="m-0 fw-semibold">No reviews left for this course yet.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
