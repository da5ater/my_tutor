<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <!-- Breadcrumbs -->
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0 m-0">
          <li class="breadcrumb-item">
            <%= link_to courses_path, class: "text-decoration-none text-secondary fw-semibold" do %>
              <i class="fa-solid fa-book-open me-1"></i> Courses
            <% end %>
          </li>
          <li class="breadcrumb-item active text-dark fw-extrabold" aria-current="page">
            <%= @course.title %>
          </li>
        </ol>
      </nav>

      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
        <div class="d-flex align-items-center justify-content-between mb-4">
          <span class="badge mb-0 px-3 py-2 fw-semibold" style="background-color: rgba(255, 56, 92, 0.1); color: #ff385c; border-radius: 50px;">
            <i class="fa-solid fa-graduation-cap me-1"></i> Course Details
          </span>
          <span class="text-muted small">
            <i class="fa-regular fa-clock me-1"></i> Created <%= @course.created_at.strftime('%b %d, %Y') %>
          </span>
        </div>
        
        <h1 class="display-6 fw-extrabold text-dark mb-3 font-heading"><%= @course.title %></h1>
        
        <div class="d-flex align-items-center gap-2 mb-4 pb-3 border-bottom">
          <span class="badge bg-light text-secondary border px-3 py-2 fw-normal"><i class="fa-solid fa-chalkboard-user me-1"></i> Tutor: <%= @course.user&.email || "Unknown Tutor" %></span>
        </div>
        
        <div class="trix-content text-secondary mb-5 fs-5" style="line-height: 1.6;">
          <%= @course.description %>
        </div>

        <div class="border-top pt-4 d-flex justify-content-between align-items-center">
          <div>
            <%= link_to courses_path, class: "btn btn-link px-0 text-decoration-none text-secondary fw-semibold d-inline-flex align-items-center gap-2" do %>
              <i class="fa-solid fa-arrow-left"></i> Back to Courses
            <% end %>
          </div>
          <div class="d-flex gap-2">
            <%= link_to edit_course_path(@course), class: "btn btn-outline-primary fw-bold px-4 py-2.5 rounded-pill" do %>
              <i class="fa-solid fa-pen-to-square me-1"></i> Edit
            <% end %>
            <%= button_to @course, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this course?" }, class: "btn btn-danger fw-bold px-4 py-2.5 rounded-pill" do %>
              <i class="fa-solid fa-trash me-1"></i> Delete
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
